{
  "name": "pi-telegram",
  "version": "0.3.4",
  "description": "Pi-Telegram: Bridge Telegram bots to pi coding agent via RPC",
  "type": "module",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsx --watch src/main.ts",
    "pitg": "node dist/main.js",
    "release": "node scripts/release.mjs",
    "prepublishOnly": "npm run build"
  },
  "bin": {
    "pitg": "dist/main.js"
  },
  "dependencies": {
    "@grammyjs/auto-chat-action": "^0.1.1",
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/commands": "^1.2.0",
    "@grammyjs/files": "^1.1.1",
    "@grammyjs/hydrate": "^1.6.0",
    "@grammyjs/menu": "^1.3.1",
    "@grammyjs/runner": "^2.0.3",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/markdown-it": "^14.1.2",
    "@types/sanitize-html": "^2.16.0",
    "croner": "^9.1.0",
    "grammy": "^1.41.1",
    "markdown-it": "^14.1.1",
    "markdown-it-cjk-friendly": "^2.0.2",
    "sanitize-html": "^2.17.1"
  },
  "devDependencies": {
    "@grammyjs/types": "^3.25.0",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "telegram",
    "telegram-bot",
    "pi",
    "pi-coding-agent",
    "grammy",
    "rpc",
    "ai-agent",
    "cli"
  ]
}
